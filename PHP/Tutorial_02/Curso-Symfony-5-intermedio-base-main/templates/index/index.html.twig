{% extends 'base.html.twig' %}

{% block title %}Tareas por hacer
{% endblock %}

{% block body %}
	<h1>Tareas por hacer</h1>

	{% include 'comunes/_mensajes.html.twig' %}

	<table class="table table-striped">
		<thead>
			<tr>
				<th scope="col">#</th>
				<th scope="col">Descripción</th>
				<th scope="col">Acciones</th>
			</tr>
		</thead>

		<tbody>
			{% for index, tarea in tareas %}
				<tr>
					<th scope="row">{{ index + 1 }}</th>

					<td class="descripcion">
						<span class="{{ tarea.finalizada ? 'text-muted' }}">
							{% if tarea.finalizada %}
								<del>{{ tarea.descripcion }}</del>
							{% else %}
								{{ tarea.descripcion }}
							{% endif %}
						</span>
					</td>

					<td>
						<a href="{{ path('tarea_edit', { id: tarea.id }) }}">
							Editar
						</a>

						<a href="#" class="btn btn-link ml-3 finalizar" data-url="{{ path('tarea_finalizar', { id: tarea.id }) }}" data-texto-contrario="{{ tarea.finalizada ? 'Finalizar' : 'Desfinalizar' }}">
							{{ tarea.finalizada ? 'Desfinalizar' : 'Finalizar' }}
						</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<th colspan="3" scope="row">
						No se han encontrado resultados.
					</th>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<div class="mt-3">
		{{
            include('comunes/_paginacion.html.twig', {
                elementos_por_pagina: constant('App\\Controller\\IndexController::ELEMENTOS_POR_PAGINA'),
                numero_total_elementos: tareas.count,
                pagina_actual: pagina
            })
        }}
	</div>
{% endblock %}
