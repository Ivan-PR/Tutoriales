<base:BaseView x:Class="OpenWebinarsMVVM.View.LoginView"
        x:TypeArguments="vm:LoginViewModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenWebinarsMVVM.View"
        xmlns:base="clr-namespace:OpenWebinarsMVVM.View.Base"
        xmlns:vm="clr-namespace:OpenWebinarsMVVM.ViewModel"
        mc:Ignorable="d"
        Title="LoginView" Height="450" Width="800">
    <StackPanel>
        <Label Content="Username" />
        <TextBlock x:Name="TextBoxUsername" Text="{Binding UserName}" />

        <Label Content="Password" />
        <TextBlock x:Name="TextBoxPassword" Text="{Binding PassWord}" />

        <Button x:Name="ButtonLogin" Content="Login" Command="{Binding DoLoginCommand}" />
    </StackPanel>
</base:BaseView>